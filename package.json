{
  "name": "@forgesworn/toll-booth",
  "version": "3.8.0",
  "type": "module",
  "description": "Monetise any API with HTTP 402 payments. Payment-rail agnostic middleware for Express, Hono, Deno, Bun, and Workers.",
  "license": "MIT",
  "keywords": [
    "l402",
    "lightning",
    "paywall",
    "micropayments",
    "middleware",
    "cashu",
    "ecash",
    "nostr",
    "nwc",
    "bitcoin",
    "express",
    "hono",
    "deno",
    "bun",
    "cloudflare-workers",
    "serverless",
    "typescript",
    "macaroon",
    "http-402",
    "api-monetisation",
    "payment-gateway",
    "ai-agents",
    "machine-payments",
    "api-monetization",
    "x402"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forgesworn/toll-booth.git"
  },
  "homepage": "https://github.com/forgesworn/toll-booth#readme",
  "funding": "https://github.com/forgesworn/toll-booth#support",
  "bin": {
    "toll-booth": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./backends/phoenixd": {
      "import": "./dist/backends/phoenixd.js",
      "types": "./dist/backends/phoenixd.d.ts"
    },
    "./backends/lnd": {
      "import": "./dist/backends/lnd.js",
      "types": "./dist/backends/lnd.d.ts"
    },
    "./backends/cln": {
      "import": "./dist/backends/cln.js",
      "types": "./dist/backends/cln.d.ts"
    },
    "./backends/nwc": {
      "import": "./dist/backends/nwc.js",
      "types": "./dist/backends/nwc.d.ts"
    },
    "./backends/lnbits": {
      "import": "./dist/backends/lnbits.js",
      "types": "./dist/backends/lnbits.d.ts"
    },
    "./storage/sqlite": {
      "import": "./dist/storage/sqlite.js",
      "types": "./dist/storage/sqlite.d.ts"
    },
    "./storage/memory": {
      "import": "./dist/storage/memory.js",
      "types": "./dist/storage/memory.d.ts"
    },
    "./adapters/express": {
      "import": "./dist/adapters/express.js",
      "types": "./dist/adapters/express.d.ts"
    },
    "./adapters/web-standard": {
      "import": "./dist/adapters/web-standard.js",
      "types": "./dist/adapters/web-standard.d.ts"
    },
    "./hono": {
      "import": "./dist/adapters/hono.js",
      "types": "./dist/adapters/hono.d.ts"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    "!dist/**/*.d.ts.map",
    "llms.txt"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "test": "vitest run",
    "test:integration": "bash scripts/test-integration.sh",
    "test:integration:ln": "bash scripts/test-integration.sh --ln-only",
    "test:integration:cashu": "bash scripts/test-integration.sh --cashu-only",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test",
    "prepare": "patch-package"
  },
  "dependencies": {
    "@cashu/cashu-ts": "^3.6.0",
    "better-sqlite3": "^11.8.0",
    "macaroon": "^3.0.4",
    "nostr-core": "^0.4.0",
    "qrcode": "^1.5.4"
  },
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0",
    "hono": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "hono": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.11",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.6",
    "@types/qrcode": "^1.5.6",
    "express": "^5.2.1",
    "hono": "^4.12.7",
    "patch-package": "^8.0.1",
    "semantic-release": "^25.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
